{
  "version": 2,
  "buildCommand": "cd client && npm install && npm run build",
  "outputDirectory": "client/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/server/index.js" },
    { "source": "/((?!api).*)", "destination": "/index.html" }
  ],
  "functions": {
    "server/index.js": {
      "memory": 512,
      "maxDuration": 30
    }
  }
}
